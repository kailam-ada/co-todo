# Configuration Supabase (exposée côté client via le préfixe VITE_)
# Récupérez ces valeurs dans : Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-publique

# CAPTCHA Cloudflare Turnstile (clé publique « site key »).
# Laisser vide pour désactiver le CAPTCHA. Clé de test Cloudflare (toujours OK) :
# 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=
